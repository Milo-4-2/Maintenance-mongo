meta {
  name: log in
  type: http
  seq: 3
}

post {
  url: http://localhost:3000/api/auth/login
  body: json
  auth: none
}

body:json {
  {
    "email": "test@mail.com",
    "password": "password"
  }
}

tests {
  test("Login successful", () => {
    expect(res.status).to.equal(200);
  });
  
  const body = res.getBody();
  bru.setVar("token", body.data.token);
}

settings {
  encodeUrl: true
  timeout: 0
}
