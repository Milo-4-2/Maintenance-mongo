meta {
  name: delete comment
  type: http
  seq: 9
}

delete {
  url: http://localhost:3000/api/tasks/{{id}}/comments/{{commentid}}
  body: none
  auth: inherit
}

headers {
  Authorization: Bearer {{token}}
}

tests {
  test("Should delete created comment", () => {
    const body = res.getBody();
  
    expect(res.getStatus()).to.equal(200);
    expect(body.success).to.equal(true);
  });
}

settings {
  encodeUrl: true
  timeout: 0
}
