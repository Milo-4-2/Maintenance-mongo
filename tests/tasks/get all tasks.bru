meta {
  name: get all tasks
  type: http
  seq: 3
}

get {
  url: http://localhost:3000/api/tasks
  body: none
  auth: inherit
}

headers {
  Authorization: Bearer {{token}}
}

tests {
  test("Should return all tasks", () => {
    const body = res.getBody();
  
    expect(res.getStatus()).to.equal(200);
    expect(body.success).to.equal(true);
  });
}

settings {
  encodeUrl: true
  timeout: 0
}
