meta {
  name: delete subtask
  type: http
  seq: 7
}

delete {
  url: http://localhost:3000/api/tasks/{{id}}/subtasks/{{subtaskid}}
  body: none
  auth: inherit
}

headers {
  Authorization: Bearer {{token}}
}

tests {
  test("Should delete created subtask", () => {
    const body = res.getBody();
  
    expect(res.getStatus()).to.equal(200);
    expect(body.success).to.equal(true);
  });
}

settings {
  encodeUrl: true
  timeout: 0
}
