meta {
  name: update task
  type: http
  seq: 4
}

put {
  url: http://localhost:3000/api/tasks/{{id}}
  body: json
  auth: inherit
}

headers {
  Authorization: Bearer {{token}}
}

body:json {
  {
    "titre": "tache test updated"
  }
}

tests {
  test("Should update created task", () => {
    const body = res.getBody();
  
    expect(res.getStatus()).to.equal(200);
    expect(body.success).to.equal(true);
  });
}

settings {
  encodeUrl: true
  timeout: 0
}
