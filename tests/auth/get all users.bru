meta {
  name: get all users
  type: http
  seq: 3
}

get {
  url: http://localhost:3000/api/auth/users
  body: none
  auth: inherit
}

headers {
  Authorization: Bearer {{token}}
}

tests {
  test("Get users list successfully", () => {
    const body = res.getBody();
  
    expect(res.getStatus()).to.equal(200);
    expect(body.success).to.equal(true);
    
    expect(body.count).to.be.greaterThan(1);
    
    const userExists = body.data.some(user =>
        user.username === "test_username" &&
        user.email === "test@mail.com"
    );
  
    expect(userExists).to.equal(true);
  });
}

settings {
  encodeUrl: true
  timeout: 0
}
