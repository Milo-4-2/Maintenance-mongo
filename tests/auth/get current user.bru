meta {
  name: get current user
  type: http
  seq: 4
}

get {
  url: http://localhost:3000/api/auth/me
  body: none
  auth: inherit
}

headers {
  Authorization: Bearer {{token}}
}

tests {
  test("Should return current user", () => {
    const body = res.getBody();
  
    expect(res.getStatus()).to.equal(200);
    expect(body.success).to.equal(true);
  
    expect(body.data.email).to.equal("test@mail.com");
    expect(body.data.username).to.equal("test_username");
    expect(body.data.firstName).to.equal("test_name");
    expect(body.data.lastName).to.equal("test_lastname");
  });
}

settings {
  encodeUrl: true
  timeout: 0
}
